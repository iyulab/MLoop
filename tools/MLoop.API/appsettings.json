{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      { "Endpoint": "POST:/predict", "Period": "1m", "Limit": 60 },
      { "Endpoint": "*", "Period": "1m", "Limit": 100 }
    ]
  },
  "Jwt": {
    "Key": "MLoop-Default-Secret-Key-Change-In-Production-Min-32-Chars",
    "Issuer": "MLoop.API",
    "Audience": "MLoop.Client"
  },
  "Cors": {
    "Origins": []
  },
  "Serve": {
    "Cache": {
      "MaxCachedModels": 8,
      "PreloadModels": []
    }
  }
}
